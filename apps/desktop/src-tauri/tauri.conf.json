{
 "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
 "productName": "UNVET Desktop",
 "version": "1.1.0",
 "identifier": "network.usagi.unvet.desktop",
 "build": {
  "frontendDist": "../dist",
  "beforeBuildCommand": "npm run build"
 },
 "app": {
  "windows": [
   {
    "title": "UNVET Desktop",
    "width": 1260,
    "height": 860,
    "minWidth": 1260,
    "minHeight": 860,
    "resizable": false,
    "maximizable": false,
    "fullscreen": false
   }
  ],
  "security": {
   "csp": null
  }
 },
 "bundle": {
  "active": true,
  "targets": "all",
  "icon": [
   "icons/32x32.png",
   "icons/128x128.png",
   "icons/128x128@2x.png",
   "icons/icon.icns",
   "icons/icon.ico"
  ]
 }
}